---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import CompassClock from '../components/CompassClock.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featuredPost = posts[0];
const restPosts = posts.slice(1, 7);
---

<BaseLayout title="小陈的博客" description="技术笔记、项目经验和一些有趣的想法">
  <CompassClock />

  <!-- Hero -->
  <section class="hero">
    <span class="hero-label">个人博客</span>
    <h1>小陈的博客</h1>
    <div class="hero-line"></div>
    <p>技术笔记、项目经验<br />和一些有趣的想法。</p>
  </section>

  <!-- Featured Post -->
  {featuredPost && (
    <section class="featured">
      <span class="section-label">最新发布</span>
      <a href={`/blog/${featuredPost.id.replace(/\.md$/, '')}`} class="featured-link">
        {featuredPost.data.image ? (
          <div class="featured-image">
            <img src={featuredPost.data.image} alt={featuredPost.data.title} />
          </div>
        ) : (
          <div class="featured-image featured-placeholder"></div>
        )}
        <div class="featured-body">
          <time datetime={featuredPost.data.pubDate.toISOString()}>
            {featuredPost.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          <h2>{featuredPost.data.title}</h2>
          <p>{featuredPost.data.description}</p>
          <span class="read-more">阅读全文 →</span>
        </div>
      </a>
    </section>
  )}

  <!-- More Posts -->
  {restPosts.length > 0 && (
    <section class="more-posts">
      <div class="section-header">
        <span class="section-label">更多文章</span>
        <a href="/blog" class="view-all">查看全部 →</a>
      </div>
      <div class="post-grid">
        {restPosts.map(post => (
          <PostCard
            title={post.data.title}
            href={`/blog/${post.id.replace(/\.md$/, '')}`}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            image={post.data.image}
          />
        ))}
      </div>
    </section>
  )}
</BaseLayout>

<style>
  /* Hero */
  .hero {
    padding: 8rem 0 6rem;
    position: relative;
    z-index: 1;
  }
  .hero-label {
    display: block;
    font-size: 0.65rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--c-text-muted);
    margin-bottom: 2rem;
  }
  .hero h1 {
    font-family: var(--font-heading);
    font-size: clamp(3.5rem, 8vw, 6rem);
    font-weight: 900;
    line-height: 1.05;
    margin-bottom: 2rem;
    letter-spacing: -0.03em;
  }
  .hero-line {
    width: 60px;
    height: 1px;
    background: var(--c-text);
    margin-bottom: 2rem;
    opacity: 0.25;
  }
  .hero p {
    color: var(--c-text-soft);
    font-size: 1rem;
    line-height: 1.8;
  }

  /* Section Labels */
  .section-label {
    display: block;
    font-size: 0.65rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--c-text-muted);
    margin-bottom: 2.5rem;
  }

  /* Featured Post */
  .featured {
    padding: 8rem 0;
    border-top: 1px solid var(--c-border);
    position: relative;
    z-index: 1;
  }
  .featured-link {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    text-decoration: none;
    color: inherit;
  }
  .featured-link:hover { text-decoration: none; }
  .featured-link:hover .featured-image img {
    transform: scale(1.02);
  }
  .featured-link:hover h2 {
    color: var(--c-accent);
  }
  .featured-image {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--c-bg-soft);
  }
  .featured-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .featured-placeholder {
    background: var(--c-bg-soft);
  }
  .featured-body time {
    display: block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--c-text-muted);
    margin-bottom: 1rem;
  }
  .featured-body h2 {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 1rem;
    transition: color 0.2s;
  }
  .featured-body p {
    color: var(--c-text-soft);
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }
  .read-more {
    font-size: 0.85rem;
    color: var(--c-text-muted);
    border-bottom: 1px solid var(--c-border);
    padding-bottom: 2px;
    transition: color 0.2s, border-color 0.2s;
  }
  .featured-link:hover .read-more {
    color: var(--c-text);
    border-color: var(--c-text);
  }

  /* More Posts */
  .more-posts {
    padding: 8rem 0;
    border-top: 1px solid var(--c-border);
    position: relative;
    z-index: 1;
  }
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .view-all {
    font-size: 0.8rem;
    color: var(--c-text-muted);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding-bottom: 2px;
    transition: color 0.2s, border-color 0.2s;
  }
  .view-all:hover {
    color: var(--c-text);
    border-color: var(--c-text);
    text-decoration: none;
  }
  .post-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3.5rem;
  }

  @media (max-width: 768px) {
    .hero { padding: 4rem 0 3rem; }
    .hero h1 { font-size: 2.2rem; }
    .featured { padding: 3rem 0; }
    .featured-link {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .more-posts { padding: 3rem 0; }
    .post-grid { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>
