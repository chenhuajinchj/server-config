---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import CompassClock from '../components/CompassClock.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---

<BaseLayout title="小陈的博客" description="技术笔记、项目经验和一些有趣的想法">
  <CompassClock />
  <section class="hero">
    <h1>你好，我是小陈 👋</h1>
    <p>这里记录技术笔记、项目经验和一些有趣的想法。</p>
  </section>

  <section class="recent-posts">
    <h2>最新文章</h2>
    {posts.map(post => (
      <PostCard
        title={post.data.title}
        href={`/blog/${post.id.replace(/\.md$/, '')}`}
        description={post.data.description}
        pubDate={post.data.pubDate}
        tags={post.data.tags}
      />
    ))}
    <a href="/blog" class="view-all">查看全部文章 →</a>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 2rem 0 3rem;
    position: relative;
    z-index: 1;
  }
  .hero h1 {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
  }
  .hero p {
    color: var(--c-text-soft);
    font-size: 1.1rem;
  }
  .recent-posts h2 {
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }
  .recent-posts {
    position: relative;
    z-index: 1;
  }
  .view-all {
    display: inline-block;
    margin-top: 1rem;
    font-size: 0.9rem;
  }
</style>
