---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const filtered = headings.filter(h => h.depth >= 2 && h.depth <= 3);
---

{filtered.length > 0 && (
  <nav class="toc">
    <h4 class="toc-title">目录</h4>
    <ul class="toc-list">
      {filtered.map(h => (
        <li class:list={["toc-item", { "toc-h3": h.depth === 3 }]}>
          <a href={`#${h.slug}`}>{h.text}</a>
        </li>
      ))}
    </ul>
  </nav>
)}

<style>
  .toc {
    padding: 1rem 1.2rem;
    background: var(--c-bg-soft);
    border-radius: var(--radius);
    margin-bottom: 2rem;
  }
  .toc-title {
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--c-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .toc-list {
    list-style: none;
    padding: 0;
  }
  .toc-item { margin-bottom: 0.3rem; }
  .toc-item a {
    font-size: 0.85rem;
    color: var(--c-text-soft);
    text-decoration: none;
  }
  .toc-item a:hover { color: var(--c-accent); }
  .toc-h3 { padding-left: 1rem; }
</style>
