---
interface Props {
  title: string;
  href: string;
  description: string;
  pubDate: Date;
  tags?: string[];
}

const { title, href, description, pubDate, tags = [] } = Astro.props;
const dateStr = pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
---

<article class="post-card">
  <a href={href} class="post-card-link">
    <h3 class="post-card-title">{title}</h3>
    <p class="post-card-desc">{description}</p>
    <div class="post-card-meta">
      <time datetime={pubDate.toISOString()}>{dateStr}</time>
      {tags.length > 0 && (
        <span class="post-card-tags">
          {tags.map(tag => <span class="tag">#{tag}</span>)}
        </span>
      )}
    </div>
  </a>
</article>

<style>
  .post-card {
    padding: 1.2rem 0;
    border-bottom: 1px solid var(--c-border);
  }
  .post-card:last-child { border-bottom: none; }
  .post-card-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }
  .post-card-link:hover .post-card-title { color: var(--c-accent); }
  .post-card-title {
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 0.4rem;
    transition: color 0.2s;
  }
  .post-card-desc {
    color: var(--c-text-soft);
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .post-card-meta {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    font-size: 0.8rem;
    color: var(--c-text-muted);
  }
  .post-card-tags { display: flex; gap: 0.4rem; }
  .tag {
    color: var(--c-accent);
    font-size: 0.8rem;
  }
</style>
