---
interface Props {
  title: string;
  href: string;
  description: string;
  pubDate: Date;
  tags?: string[];
  image?: string;
}

const { title, href, description, pubDate, tags = [], image } = Astro.props;
const dateStr = pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
---

<article class="post-card">
  <a href={href} class="post-card-link">
    <div class="post-card-image-wrap">
      {image ? (
        <img src={image} alt={title} class="post-card-image" loading="lazy" />
      ) : (
        <div class="post-card-image post-card-placeholder" />
      )}
    </div>
    <div class="post-card-body">
      <time datetime={pubDate.toISOString()} class="post-card-date">{dateStr}</time>
      <h3 class="post-card-title">{title}</h3>
      <p class="post-card-desc">{description}</p>
    </div>
  </a>
</article>

<style>
  .post-card-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }
  .post-card-link:hover { text-decoration: none; }
  .post-card-link:hover .post-card-image {
    transform: scale(1.03);
  }
  .post-card-link:hover .post-card-title {
    color: var(--c-accent);
  }
  .post-card-image-wrap {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    margin-bottom: 1.25rem;
    background: var(--c-bg-soft);
  }
  .post-card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .post-card-placeholder {
    background: var(--c-bg-soft);
  }
  .post-card-body {
    padding: 0 0.1rem;
  }
  .post-card-date {
    display: block;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--c-text-muted);
    margin-bottom: 0.6rem;
  }
  .post-card-title {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 700;
    line-height: 1.4;
    margin-bottom: 0.5rem;
    transition: color 0.3s;
  }
  .post-card-desc {
    color: var(--c-text-soft);
    font-size: 0.88rem;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
