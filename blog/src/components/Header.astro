---
const navItems = [
  { text: '首页', href: '/' },
  { text: '博客', href: '/blog' },
  { text: '标签', href: '/tags' },
  { text: '关于', href: '/about' },
];
---

<header class="header">
  <nav class="container header-nav">
    <a href="/" class="header-logo">小陈的博客</a>
    <div class="header-links">
      {navItems.map(item => (
        <a href={item.href} class:list={["nav-link", { active: Astro.url.pathname.startsWith(item.href) && item.href !== '/' || Astro.url.pathname === item.href }]}>
          {item.text}
        </a>
      ))}
      <button id="theme-toggle" class="theme-btn" aria-label="切换主题">
        <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
        <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
    </div>
  </nav>
</header>

<style>
  .header {
    height: var(--header-height);
    border-bottom: 1px solid var(--c-border);
    position: sticky;
    top: 0;
    background: var(--c-bg);
    z-index: 100;
    backdrop-filter: blur(8px);
  }
  .header-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }
  .header-logo {
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--c-text);
  }
  .header-logo:hover { text-decoration: none; color: var(--c-accent); }
  .header-links {
    display: flex;
    align-items: center;
    gap: 1.2rem;
  }
  .nav-link {
    color: var(--c-text-soft);
    font-size: 0.9rem;
    transition: color 0.2s;
  }
  .nav-link:hover, .nav-link.active {
    color: var(--c-accent);
    text-decoration: none;
  }
  .theme-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--c-text-soft);
    padding: 4px;
    display: flex;
    align-items: center;
    transition: color 0.2s;
  }
  .theme-btn:hover { color: var(--c-accent); }
  :global([data-theme="dark"]) .icon-sun { display: block; }
  :global([data-theme="dark"]) .icon-moon { display: none; }
  :global(:not([data-theme="dark"])) .icon-sun { display: none; }
  :global(:not([data-theme="dark"])) .icon-moon { display: block; }
</style>
