---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <p>&copy; {year} 小陈的博客 · 由 <a href="https://astro.build" target="_blank" rel="noopener">Astro</a> 驱动</p>
    <p class="footer-links">
      <a href="/rss.xml">RSS</a>
    </p>
  </div>
</footer>

<style>
  .footer {
    margin-top: 6rem;
    padding: 2.5rem 0;
    text-align: center;
    font-size: 0.85rem;
    color: var(--c-text-muted);
  }
  .footer a {
    color: var(--c-text-muted);
    text-decoration-color: transparent;
  }
  .footer a:hover {
    color: var(--c-text-soft);
    text-decoration-color: var(--c-text-soft);
  }
  .footer-links { margin-top: 0.5rem; }
</style>
